begin

end;

function TRSFarmPatch.Harvest(): Boolean;
var
  inactivity: TCountDown;
begin
  if not Self.WalkInteract(['Pick', 'Harvest']) then
    Exit;

  //TODO wait until movement stops?

  inactivity.Start(2400);
  repeat
    if Self.IsEmpty                             then Exit(Self.Harvested := True);
    if Inventory.IsFull                         then Exit(True);
    if XPBar.EarnedXP                           then inactivity.Restart;

    //TODO do some antiban stuff??
  until inactivity.IsFinished;
end;

function TRSFarmPatch.Plant(): Boolean;
var
  selected: Integer;
  inactivity: TCountDown;
begin
  if Self.WalkFind = [] then
    Exit;

  if not Inventory.Open() then
  begin
    Self.DebugLn('Failed to open inventory');
    Exit;
  end;

  selected := Inventory.GetSelected;
  writeln selected;
  if selected >= 0 then
  begin
    if selected <> Self.SeedSlot then
    begin
      Self.DebugLn('Item selected that''s not a preselected seed. Selecting now.');
      Inventory.Select(Self.Seed, True);
    end else
      Self.DebugLn('Seed already selected.');
  end else
  begin
    Self.DebugLn('Selecting seed now.');
    Inventory.Select(Self.Seed, True);
  end;

  if Inventory.GetSelected < 0 then
  begin
    Self.DebugLn('Failed to selected the correct seed for planting');
    Exit;
  end else
    Self.DebugLn('Successfuly selected the correct seed to plant');

  //clear previous earned xp.
  XPBar.EarnedXP;

  if not Self.Interact() then
    Exit;

  //Clear cached seed slot from preselect
  Self.SeedSlot := -1;


  inactivity.Start(2400); //calc distance or something
  repeat
    if not Self.IsEmpty then Exit(Self.Planted := True);
    if XPBar.EarnedXP then Exit(Self.Planted := True);

    //TODO do some antiban stuff??
  until inactivity.IsFinished;
end;

function TRSFarmPatch.FertileSoil(): Boolean;
var
  inactivity: TCountDown;
begin
  if not (Self.WalkFind and Magic.CastSpell(ERSSpell.FERTILE_SOIL)) then
    Exit;

  XPBar.EarnedXP;
  if not Self.Interact() then
    Exit;

  inactivity.Start(2400); //calc distance or something
  repeat
    if XPBar.EarnedXP then Exit(Self.Composted := True);

    //TODO do some antiban stuff??
  until inactivity.IsFinished;
end;

function TRSFarmPatch.Compost(): Boolean;
var
  selected: Integer;
  inactivity: TCountDown;
begin
  if Self.CompostMethod = ERSCompost.FERTILE_SOIL then
    Exit(Self.FertileSoil);

  if not Self.WalkFind then
    Exit;

  selected := Inventory.GetSelected;
  if ((selected >= 0) and (selected <> Self.compostSlot)) or (selected = -1) then
    Inventory.Select(Self.CompostMethod.ToString, True);

  Self.compostSlot := -1;
  XPBar.EarnedXP;

  if (Inventory.GetSelected = -1) or (not Self.Interact()) then
    Exit;

  //TODO wait for player to finish moving.

  inactivity.Start(2400); //calc distance or something
  repeat
    if XPBar.EarnedXP then Exit(Self.Composted := True);

    //TODO do some antiban stuff??
  until inactivity.IsFinished;
end;

