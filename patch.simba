function TRSFarmPatch.Resurrect(): Boolean;
var
  patchResults: TRSPatchFindResults;
  spellbookSwap: Boolean;
begin
  if spellbookSwap := (Magic.GetSpellBook() = ERSSpellBook.LUNAR) and not Magic.SpellBookSwap(ERSSpellBook.ARCEUUS) then
    Exit;

  if Magic.GetSpellBook() <> ERSSpellBook.ARCEUUS then
    Exit;

  patchResults := Self.WalkFind();
  if patchResults = [] then
    Exit;

  XPBar.EarnedXP();
  if Magic.CastSpell(ERSSpell.RESURRECT_CROPS) and Self.Interact() then
  begin
    //TODO wait for xp drop or chat.hascontinue

    //if chat.hascontinue then rescrop failed
    //if earned xp then complete, maybe check if composted??

  end;
  Inventory.Slots
end;

function TRSFarmPatch.CleanHerbs(): Boolean;
const GRIMY_HERBS = TRSToolLeprechaun.NOTABLE_ITEMS[TRSToolLeprechaun.GRIMY_HERBS_START..TRSToolLeprechaun.GRIMY_HERBS_END];
var
  slot: Integer;
  slots: TIntegerArray;
begin
  if not Inventory.Items.Find(GRIMY_HERBS, slots) then
    Exit;

  for slot in ClusteredClickPattern(Inventory.Slots.Boxes(), slots) do
  begin
    Inventory.Slots.Interact(slot, 'Clean');
    Sleep(50, 200);
  end;
end;

function TRSFarmPatch.NoteItems(): Boolean;
begin
  Result := ToolLeprechaun.NoteItems();
end;

function TRSFarmPatch.HandleAction(action: ERSFarmPatchAction): Boolean;
begin
  case action of
    //TODO CHECK_HEALTH
    ERSFarmPatchAction.HARVEST: Result := Self.Harvest();
    ERSFarmPatchAction.PLANT: Result := Self.Plant();
    ERSFarmPatchAction.COMPOST: Result := Self.Compost();
    ERSFarmPatchAction.CAST_FERTILE_SOIL: Result := Self.FertileSoil();
    //TODO CURE
    //TODO CAST_CURE_PLANT
    //TODO WITHDRAW_PLANT_CURE
    //TODO WITHDRAW_COMPOST
    //TODO DEPOSIT_BUCKETS
    //TODO CLOSE_INTERFACE
    //TODO CHOP_TREE
    //TODO GARDNER_CHOP_TREE
    ERSFarmPatchAction.CLEAN_HERBS: Result := Self.CleanHerbs();
    ERSFarmPatchAction.NOTE_ITEMS: Result := Self.NoteItems();
  end;
end;

function TRSFarmPatch.Run(): Boolean;
var
  xp: TRSXPBar;
  inactivity: TCountDown;
  state: ERSFarmPatchState;
  action: ERSFarmPatchAction;
begin
  if (not FarmingTravel.Travel(Self.TravelMethod)) or (Self.WalkFind = []) then
  begin
    Self.DebugLn('Failed to tavel, or find farming patch %s. Skipping it', [ToString(Self.Descriptor)]);
    Exit;
  end;

  xp.Setup;
  inactivity.Start(2 * ONE_MINUTE);
  repeat
    state := Self.GetState;
    Self.DebugLn('Current patch state: %s', [ToString(state)]);
    //if Self.Completed then
    //  Exit(True);

    if xp.EarnedXP() then inactivity.Restart();

    action := Self.GetAction(state);
    Self.DebugLn('Chosen action: %s. Handling now.', [ToString(action)]);
    Self.HandleAction(action);
  until inactivity.IsFinished;
end;

var
  patch: TRSFarmPatch;
  img: TImage;
begin
  FarmingTravel.Init;
  FarmingTravel.Helper._LoadMap(TRSFarmingTravelHelper.HOSIDIOUS_MAP);
  patch.Descriptor := ERSFarmPatchDescriptor.HOSIDIOUS_ALLOT_N;
  patch.TravelMethod := ERSFarmingTravel.XERIC_TALISMAN_GLADE;
  patch.Seed := 'Watermelon seed';
  //patch.WalkInteract(['Harvest']);
  patch.run;
end.
